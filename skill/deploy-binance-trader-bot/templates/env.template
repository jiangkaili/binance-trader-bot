# ============================================================
# Binance Futures API credentials — DO NOT commit real keys!
# Copy this file to .env and fill in your values:  cp .env.example .env
# ============================================================

# ---- API Keys ----
# Testnet: https://testnet.binancefuture.com
# Production: https://www.binance.com/en/my/settings/api-management
# Required permission: "Futures Trading" (USDⓈ-M). NEVER enable "Withdrawals".
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ---- Environment ----
# true  = testnet (paper trading, fake USDT, recommended for first run)
# false = production (real money)
USE_TESTNET=true

# ---- Network Proxy (optional) ----
# Leave blank if you can reach Binance directly.
# Examples: 127.0.0.1:7890 (Clash), 127.0.0.1:1080 (SS/V2Ray), 127.0.0.1:12000 (iKuuu)
PROXY_HOST=
PROXY_PORT=0

# ---- Trading ----
DEFAULT_SYMBOL=BTCUSDT
MARKET=futures

# ---- Risk (safety rails) ----
RISK_MAX_POSITION_PCT=0.30
RISK_MAX_DAILY_LOSS_PCT=0.05
RISK_MAX_OPEN_ORDERS=10
RISK_MAX_SINGLE_ORDER_VALUE_PCT=0.10

# ---- Storage ----
DB_PATH=./data/trades.db
CACHE_DIR=./data/cache
LOG_LEVEL=INFO
