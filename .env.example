# ============================================================
# Binance Futures API credentials — DO NOT commit real keys!
# Binance 合约 API 密钥 — 切勿提交真实密钥!
# ============================================================
# Get yours from: https://www.binance.com/en/my/settings/api-management
# Create a key with "Futures Trading" permission enabled.
# For safety, enable IP whitelist on your key.
# 获取密钥: https://www.binance.com/en/my/settings/api-management
# 创建一个开启"合约交易"权限的密钥。为安全起见, 请在密钥上启用 IP 白名单。
#
# Copy this file to .env and fill in your values:
# 复制此文件为 .env 并填入你的值:
#   cp .env.example .env

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use Binance testnet (paper trading — no real money)
# 使用 Binance 测试网 (模拟交易 — 无真实资金)
# Get testnet keys from: https://testnet.binancefuture.com
USE_TESTNET=false

# ============================================================
# Network proxy (optional — only if Binance is geo-blocked)
# 网络代理 (可选 — 仅在 Binance 被地域封锁时使用)
# ============================================================
# If you can reach api.binance.com directly, leave these blank.
# If you use a local VPN/proxy, set PROXY_HOST=127.0.0.1
# 如果可以直连 api.binance.com, 留空即可。
# 如果使用本地 VPN/代理, 设置 PROXY_HOST=127.0.0.1
PROXY_HOST=
PROXY_PORT=0
